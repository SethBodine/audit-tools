#!/usr/bin/env bash
# =============================================================================
# wiki  GitHub Wiki CLI viewer for containerised environments
#
# Config (set via env or edit defaults below):
#   WIKI_REPO          owner/repo  (required)
#   WIKI_CACHE_DIR     where to store the cloned wiki (default: ~/.cache/wiki-viewer)
#   WIKI_CACHE_AGE     days before stale warning fires  (default: 7)
#
# Dependencies (auto-detected, best to worst):
#   Renderer : glow  bat  mdcat  less -R
#   Search   : fzf (interactive)  grep (always available)
# =============================================================================
# Intentionally no set -euo pipefail  many commands (grep, read, git)
# legitimately return non-zero and should not abort the script.

#  Configuration 
WIKI_REPO="${WIKI_REPO:-SethBodine/audit-tools}"
CACHE_DIR="${WIKI_CACHE_DIR:-${HOME}/.cache/wiki-viewer}"
CACHE_MAX_AGE_DAYS="${WIKI_CACHE_AGE:-7}"
WIKI_GIT_URL="https://github.com/${WIKI_REPO}.wiki.git"

#  Colours 
if [[ -t 1 ]]; then
  RED='\033[0;31m'; YELLOW='\033[1;33m'; GREEN='\033[0;32m'
  CYAN='\033[0;36m'; BOLD='\033[1m'; DIM='\033[2m'; RESET='\033[0m'
else
  RED=''; YELLOW=''; GREEN=''; CYAN=''; BOLD=''; DIM=''; RESET=''
fi

info()    { echo -e "${CYAN} ${RESET}$*"; }
warn()    { echo -e "${YELLOW}  ${RESET}$*"; }
success() { echo -e "${GREEN} ${RESET}$*"; }
err()     { echo -e "${RED} ${RESET}$*" >&2; }

#  Markdown renderer (best available) 
render_markdown() {
  local file="$1"
  if command -v glow &>/dev/null; then
    glow -p "$file"
  elif command -v bat &>/dev/null; then
    bat --language=markdown --paging=always --style=plain "$file"
  elif command -v mdcat &>/dev/null; then
    mdcat "$file" | less -R
  else
    less -R "$file"
  fi
}

#  Cache helpers 
cache_exists() { [[ -d "${CACHE_DIR}/.git" ]]; }

cache_age_days() {
  local ref="${CACHE_DIR}/.git/FETCH_HEAD"
  [[ -f "$ref" ]] || ref="${CACHE_DIR}/.git/HEAD"
  [[ -f "$ref" ]] || { echo 0; return; }
  local mtime
  # Handle both GNU stat (Linux) and BSD/macOS stat
  mtime=$(stat -c %Y "$ref" 2>/dev/null)
  if [[ -z "$mtime" ]]; then
    mtime=$(stat -f %m "$ref" 2>/dev/null)
  fi
  [[ -z "$mtime" ]] && mtime=0
  echo $(( ( $(date +%s) - mtime ) / 86400 ))
}

check_stale() {
  local age
  age=$(cache_age_days)
  if (( age >= CACHE_MAX_AGE_DAYS )); then
    warn "Wiki cache is ${age} days old  run 'wiki --update' to refresh."
  fi
}

update_cache() {
  if cache_exists; then
    info "Updating wiki cache from ${WIKI_GIT_URL} ..."
    if git -C "$CACHE_DIR" pull --quiet 2>/dev/null; then
      success "Cache updated ($(date '+%Y-%m-%d %H:%M'))."
    else
      warn "Update failed  no network? Using existing cache."
    fi
  else
    info "Cloning wiki for the first time..."
    mkdir -p "$(dirname "$CACHE_DIR")"
    if git clone --quiet "$WIKI_GIT_URL" "$CACHE_DIR" 2>/dev/null; then
      success "Wiki cached to ${CACHE_DIR}."
    else
      err "Could not clone wiki."
      err "Check WIKI_REPO='${WIKI_REPO}' and your network connection."
      return 1
    fi
  fi
}

ensure_cache() {
  if ! cache_exists; then
    warn "No local wiki cache found. Attempting to fetch..."
    update_cache || { err "Cannot continue without a cache."; return 1; }
  fi
}

#  Page discovery 
# Fallback when no _Sidebar.md exists: Home first, then all non-_ .md files.
list_page_files() {
  local home="${CACHE_DIR}/Home.md"
  { [[ -f "$home" ]] && echo "$home"; \
    find "$CACHE_DIR" -maxdepth 1 -name '*.md' ! -name '_*' | sort | grep -v "^${home}$"; \
  } 2>/dev/null
}

# Search: all .md files in cache, skipping _ files.
find_all_files() {
  find "$CACHE_DIR" -maxdepth 1 -name '*.md' ! -name '_*' | sort
}

page_title() {
  local file="$1"
  # Prefer first H1 in the file, fallback to filename (dashes  spaces, title-case)
  local h1
  h1=$(grep -m1 '^# ' "$file" 2>/dev/null | sed 's/^# //' | xargs)
  if [[ -n "$h1" ]]; then
    echo "$h1"
  else
    basename "$file" .md | tr '-' ' '
  fi
}

page_shorthand() {
  local title="$1"
  # Strip common noise words, take first meaningful token, lowercase
  local noise='^(the|a|an|and|or|for|to|of|in|on|at|with|how|run|running|using|setup|setting|up|guide|getting|started|overview)$'
  local word
  word=$(echo "$title" \
    | tr '[:upper:]' '[:lower:]' \
    | tr -cs 'a-z0-9\n' ' ' \
    | tr ' ' '\n' \
    | grep -Ev "$noise" \
    | grep -v '^$' \
    | head -1)
  # Fallback: first word of filename
  echo "${word:-$(basename "$1" .md | tr '[:upper:]' '[:lower:]' | cut -d- -f1)}"
}

# Populate global parallel arrays
PAGE_FILES=()
PAGE_TITLES=()
PAGE_SHORTHANDS=()

load_pages() {
  PAGE_FILES=(); PAGE_TITLES=(); PAGE_SHORTHANDS=()
  local seen_shorthands=()
  local sidebar="${CACHE_DIR}/_Sidebar.md"

  _register_page() {
    local f="$1" title="$2"
    [[ -f "$f" ]] || return
    local shorthand orig n=2
    shorthand=$(page_shorthand "$title")
    orig="$shorthand"
    while printf '%s\n' "${seen_shorthands[@]+"${seen_shorthands[@]}"}" | grep -qx "$shorthand"; do
      shorthand="${orig}${n}"; (( n++ ))
    done
    PAGE_FILES+=("$f")
    PAGE_TITLES+=("$title")
    PAGE_SHORTHANDS+=("$shorthand")
    seen_shorthands+=("$shorthand")
  }

  if [[ -f "$sidebar" ]]; then
    # Parse each markdown link  sed greedy match handles slugs with parentheses
    while IFS= read -r line; do
      local title slug
      # Extract display name: text between [ and ](
      title=$(echo "$line" | sed -n 's/.*\[\(.*\)\](.*/\1/p')
      # Extract slug: text between ]( and last )
      slug=$(echo "$line" | sed -n 's/.*\](\(.*\))/\1/p')
      [[ -n "$title" && -n "$slug" ]] || continue
      _register_page "${CACHE_DIR}/${slug}.md" "$title"
    done < "$sidebar"
  else
    while IFS= read -r f; do
      _register_page "$f" "$(page_title "$f")"
    done < <(list_page_files)
  fi
}

#  Index display 
show_index() {
  local age
  age=$(cache_age_days)
  echo ""
  echo -e "  ${BOLD}Wiki Pages${RESET}  ${DIM}${WIKI_REPO}  -  cache ${age}d old${RESET}"
  echo -e "  ${DIM}${RESET}"
  printf "  ${DIM}%3s  %-32s  %s${RESET}\n" "#" "Title" "Shorthand flag"
  echo -e "  ${DIM}    ${RESET}"
  local i
  for i in "${!PAGE_FILES[@]}"; do
    local num=$(( i + 1 ))
    printf "  ${CYAN}%3d${RESET}  ${BOLD}%-32s${RESET}  ${DIM}wiki --%s${RESET}\n" \
      "$num" "${PAGE_TITLES[$i]}" "${PAGE_SHORTHANDS[$i]}"
  done
  echo ""
  echo -e "  ${DIM}wiki <number|--shorthand>   wiki --menu   wiki --search <term>${RESET}"
  echo ""
}

#  Related pages 
show_related() {
  local file="$1" current_idx="$2"
  # Extract wiki-relative links from markdown, match against known page files
  local related=()
  while IFS= read -r link; do
    [[ "$link" =~ ^https?:// ]] && continue  # skip external links
    # Normalise: remove leading ./ and .md, convert %20 to space
    local slug
    slug=$(basename "$link" .md | sed 's|%20| |g; s|^./||')
    for j in "${!PAGE_FILES[@]}"; do
      (( j == current_idx )) && continue
      local fname
      fname=$(basename "${PAGE_FILES[$j]}" .md | tr '-' ' ')
      if [[ "${fname,,}" == "${slug,,}" ]]; then
        related+=("${PAGE_TITLES[$j]}  ${DIM}(wiki --${PAGE_SHORTHANDS[$j]})${RESET}")
      fi
    done
  done < <(grep -oP '\[.*?\]\(\K[^)]+' "$file" 2>/dev/null || true)

  if (( ${#related[@]} > 0 )); then
    echo ""
    echo -e "  ${YELLOW} Related pages:${RESET}"
    for rel in "${related[@]}"; do
      echo -e "     ${rel}"
    done
    echo ""
  fi
}

#  Open a page 
open_page() {
  local idx="$1"   # 0-based
  local file="${PAGE_FILES[$idx]}"
  show_related "$file" "$idx"
  render_markdown "$file"
}

#  Fuzzy / grep search 
search_pages() {
  local term="$1"

  # Interactive fzf path (no search term  launch fzf over all files recursively)
  if command -v fzf &>/dev/null && [[ -z "$term" ]]; then
    local chosen
    chosen=$(find_all_files \
      | fzf --preview 'grep --color=always -n "" {}' \
            --prompt='Wiki search > ')
    [[ -n "$chosen" ]] && render_markdown "$chosen"
    return
  fi

  [[ -n "$term" ]] || { err "Provide a search term: wiki --search <term>"; return 1; }

  echo ""
  echo -e "  ${BOLD}Search: \"${term}\"${RESET}  ${DIM}(searching all pages including sub-pages)${RESET}"
  echo -e "  ${DIM}${RESET}"

  local found=0
  local result_files=()
  local result_labels=()

  while IFS= read -r f; do
    local matches
    matches=$(grep -ic "$term" "$f" 2>/dev/null || true)
    if [[ "$matches" -gt 0 ]]; then
      (( found++ ))
      local label
      # Show relative path from cache root so sub-pages are identifiable
      label=$(realpath --relative-to="$CACHE_DIR" "$f" 2>/dev/null || basename "$f")
      # Prefer H1 title if present
      local h1
      h1=$(grep -m1 '^# ' "$f" 2>/dev/null | sed 's/^# //' | xargs)
      [[ -n "$h1" ]] && label="${h1}  ${DIM}(${label})${RESET}"
      printf "  ${CYAN}%3d${RESET}  ${BOLD}%-45b${RESET}  ${DIM}%d match(es)${RESET}\n" \
        "$found" "$label" "$matches"
      result_files+=("$f")
      result_labels+=("$label")
    fi
  done < <(find_all_files)

  if (( found == 0 )); then
    warn "No pages matched \"${term}\""
    return
  fi

  echo ""
  if (( found == 1 )); then
    info "One match  opening automatically."
    render_markdown "${result_files[0]}"
    return
  fi

  echo -ne "  Open page number (Enter to cancel): "
  read -r choice
  if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= found )); then
    render_markdown "${result_files[$(( choice - 1 ))]}"
  fi
}

#  Interactive menu (arrow-key TUI) 
interactive_menu() {
  local current=0
  local count=${#PAGE_FILES[@]}

  # Save screen, hide cursor, restore on exit
  tput smcup
  tput civis
  trap 'tput cnorm; tput rmcup; exit' INT TERM EXIT

  while true; do
    tput clear
    tput cup 0 0
    echo -e "  ${BOLD}Wiki  ${WIKI_REPO}${RESET}  ${DIM} navigate · Enter open · / search · q quit${RESET}"
    echo -e "  ${DIM}${RESET}"

    for i in "${!PAGE_FILES[@]}"; do
      if (( i == current )); then
        echo -e "  ${GREEN} ${BOLD}${PAGE_TITLES[$i]}${RESET}  ${DIM}--${PAGE_SHORTHANDS[$i]}${RESET}"
      else
        printf "    %s\n" "${PAGE_TITLES[$i]}"
      fi
    done

    echo ""
    echo -e "  ${DIM}Cache age: $(cache_age_days) day(s)${RESET}"

    # Capture keypress (handle escape sequences for arrow keys)
    local key esc
    IFS= read -rsn1 key
    if [[ "$key" == $'\x1b' ]]; then
      IFS= read -rsn2 -t 0.15 esc || true
      case "$esc" in
        '[A') (( current > 0 )) && (( current-- )) ;;          # Up
        '[B') (( current < count - 1 )) && (( current++ )) ;;  # Down
        '[5') (( current = 0 )) ;;                              # PgUp  top
        '[6') (( current = count - 1 )) ;;                      # PgDn  bottom
      esac
    elif [[ "$key" == '' ]]; then   # Enter
      tput cnorm; tput rmcup
      trap - INT TERM EXIT
      open_page "$current"
      # Re-enter menu after reading
      tput smcup; tput civis
      trap 'tput cnorm; tput rmcup; exit' INT TERM EXIT
    elif [[ "$key" == '/' ]]; then  # Quick search from menu
      tput cnorm; tput rmcup
      trap - INT TERM EXIT
      echo -ne "\n  Search: "; read -r term
      [[ -n "$term" ]] && search_pages "$term"
      echo -ne "\n  Press Enter to return to menu..."
      read -r _
      tput smcup; tput civis
      trap 'tput cnorm; tput rmcup; exit' INT TERM EXIT
    elif [[ "$key" =~ ^[kK]$ ]]; then   # vim-style k = up
      (( current > 0 )) && (( current-- ))
    elif [[ "$key" =~ ^[jJ]$ ]]; then   # vim-style j = down
      (( current < count - 1 )) && (( current++ ))
    elif [[ "$key" =~ ^[qQ]$ ]]; then
      break
    fi
  done

  trap - INT TERM EXIT
  tput cnorm; tput rmcup
}

#  Resolve a user-supplied argument to a page 
resolve_arg() {
  local raw="$1"
  local arg="${raw#--}"

  # Numeric index
  if [[ "$arg" =~ ^[0-9]+$ ]]; then
    if (( arg < 1 || arg > ${#PAGE_FILES[@]} )); then
      err "Page ${arg} out of range (1${#PAGE_FILES[@]})."
      return 1
    fi
    open_page $(( arg - 1 ))
    return
  fi

  # Exact shorthand match
  local i
  for i in "${!PAGE_SHORTHANDS[@]}"; do
    [[ "${PAGE_SHORTHANDS[$i]}" == "$arg" ]] && { open_page "$i"; return; }
  done

  # Prefix shorthand match
  for i in "${!PAGE_SHORTHANDS[@]}"; do
    [[ "${PAGE_SHORTHANDS[$i]}" == "${arg}"* ]] && { open_page "$i"; return; }
  done

  # Title substring match (case-insensitive)
  for i in "${!PAGE_TITLES[@]}"; do
    echo "${PAGE_TITLES[$i]}" | grep -qi "$arg" && { open_page "$i"; return; }
  done

  err "No page matched \"${raw}\""
  info "Run 'wiki' to list all pages, or 'wiki --search ${arg}' to search content."
  return 1
}

#  Entry point 
main() {
  case "${1:-}" in

    --update|-u)
      update_cache
      ;;

    --search|-s)
      ensure_cache; load_pages; check_stale
      search_pages "${2:-}"
      ;;

    --menu|-m)
      ensure_cache; load_pages; check_stale
      interactive_menu
      ;;

    --help|-h)
      ensure_cache; load_pages
      echo ""
      echo -e "${BOLD}wiki${RESET}  GitHub Wiki viewer  ${DIM}(${WIKI_REPO})${RESET}"
      echo ""
      echo -e "  ${CYAN}wiki${RESET}                      List all pages with shorthands"
      echo -e "  ${CYAN}wiki <number>${RESET}             Open page by number"
      echo -e "  ${CYAN}wiki --<shorthand>${RESET}        Jump directly to a page"
      echo -e "  ${CYAN}wiki --menu${RESET}  ${DIM}(-m)${RESET}         Interactive arrow-key menu"
      echo -e "  ${CYAN}wiki --search <term>${RESET}  ${DIM}(-s)${RESET} Search all pages (fzf if available)"
      echo -e "  ${CYAN}wiki --update${RESET}  ${DIM}(-u)${RESET}       Pull latest wiki from GitHub"
      echo -e "  ${CYAN}wiki --help${RESET}  ${DIM}(-h)${RESET}         Show this help"
      echo ""
      echo -e "  ${DIM}Renderer:  $(command -v glow || command -v bat || command -v mdcat || echo less)${RESET}"
      echo -e "  ${DIM}Cache:     ${CACHE_DIR}  (${CACHE_MAX_AGE_DAYS}d stale threshold)${RESET}"
      echo ""
      show_index
      ;;

    "")
      ensure_cache; load_pages; check_stale
      show_index
      ;;

    *)
      ensure_cache; load_pages; check_stale
      resolve_arg "$1"
      ;;
  esac
}

main "$@"

